{
  "app_name": "lc2install",
  "version": "1.0.0",
  "api": {
    "base_url2": "https://www.letztechance.org/lc/webservices/client.php",
    "base_url": "http://localhost/api.json",
    "endpoints": {
      "jobs_list": "?q=getListJSON&value1=1&value2=1"
    },
    "timeout_seconds": 30,
    "retry_attempts": 3
  },
  "database": {
    "filename": "lc2install.db",
    "migration_version": 4
  },
  "sync": {
    "auto_sync_enabled": false,
    "sync_interval_minutes": 60
  },
  "features": {
    "shell_commands_enabled": true,
    "file_downloads_enabled": true,
    "archive_extraction_enabled": true
  }
}